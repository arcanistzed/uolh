---
import { setDefaultNamespace, t } from "i18next";
import { localizePath } from "astro-i18next";
import { LanguageSelector } from "astro-i18next/components";

setDefaultNamespace("navbar");

const navItems = [
	{ path: "/about", label: "about" },
	{ path: "/events", label: "events" },
	{ path: "/blog", label: "blog" },
	{ path: "/governance", label: "governance" },
	{ path: "/team", label: "team" },
];
---

<style>
	:root {
		--menu-transition-duration: 300ms;
	}

	/* Respect reduced motion preferences */
	@media (prefers-reduced-motion: reduce) {
		#mobile-menu,
		#menu-line-1,
		#menu-line-2,
		#menu-line-3 {
			transition-duration: 0.001ms !important;
		}
	}
</style>

<nav
	id="site-nav"
	aria-label="Navigation Bar"
	class="relative border-b z-10 border-primary/30 bg-background/90 px-4 text-center text-primary shadow-sm backdrop-blur-none md:px-6 md:backdrop-blur"
>
	<div class="flex items-center justify-between gap-4 px-4 py-3 md:hidden">
		<a href={localizePath("/")} class="flex items-center gap-2">
			<img
				src="/logo.png"
				alt="uODPA logo"
				class="h-10 w-10 rounded-full border border-primary/30"
				loading="eager"
				decoding="async"
			/>
			<span class="text-xl font-bold text-primary">{t("home")}</span>
		</a>
		<details id="mobile-nav-details" class="relative">
			<summary
				aria-label="Toggle mobile menu"
				aria-controls="mobile-menu"
				aria-expanded="false"
				class="mobile-menu-trigger list-none rounded-md p-1 text-primary hover:bg-primary/10 hover:text-tertiary focus:ring-2 focus:ring-tertiary"
			>
				<svg
					id="menu-icon"
					class="h-8 w-8"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<line
						id="menu-line-1"
						x1="3"
						y1="6"
						x2="21"
						y2="6"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						style="transition: all var(--menu-transition-duration); transform-origin: center;"
					></line>
					<line
						id="menu-line-2"
						x1="3"
						y1="12"
						x2="21"
						y2="12"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						style="transition: all var(--menu-transition-duration); transform-origin: center;"
					></line>
					<line
						id="menu-line-3"
						x1="3"
						y1="18"
						x2="21"
						y2="18"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						style="transition: all var(--menu-transition-duration); transform-origin: center;"
					></line>
				</svg>
			</summary>
			<div
				id="mobile-menu"
				class="fixed inset-0 -z-10 flex h-screen min-h-screen w-screen flex-col items-stretch gap-3 overflow-y-auto bg-background/95 px-5 pb-6 pt-20 text-left shadow-2xl opacity-0 invisible pointer-events-none translate-y-2 scale-[0.99] backdrop-blur-md transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] supports-[height:100dvh]:h-dvh"
			>
				{
					navItems.map((item, index) => (
						<a
							href={localizePath(item.path)}
							class="nav-link"
							style={`--menu-item-delay: ${(index + 1) * 30}ms;`}
						>
							{t(item.label)}
						</a>
					))
				}
				<div
					class="flex items-center justify-center py-2"
					style={`--menu-item-delay: ${(navItems.length + 1) * 30}ms;`}
				>
					<LanguageSelector
						class="mx-2 block rounded-md border border-primary/40 bg-white/85 px-2 py-2 text-primary transition-colors duration-500 hover:bg-primary hover:text-white"
					/>
				</div>
			</div>
		</details>
	</div>
	<ul class="hidden md:flex md:items-center md:gap-1">
		<li class="mr-auto hidden md:block">
			<a
				href={localizePath("/")}
				class="flex items-center gap-3 py-2 pr-4"
			>
				<img
					src="/logo.png"
					alt="uODPA logo"
					class="h-11 w-11 rounded-full border border-primary/30"
					loading="eager"
					decoding="async"
				/>
				<span class="text-xl font-bold text-primary">{t("home")}</span>
			</a>
		</li>
		{
			navItems.map(item => (
				<li class="w-full text-center md:w-fit">
					<a href={localizePath(item.path)} class="nav-link">
						{t(item.label)}
					</a>
				</li>
			))
		}
		<li class="flex items-center justify-center py-2">
			<LanguageSelector
				class="mx-2 block rounded-md border border-primary/40 bg-white/85 px-2 py-2 text-primary transition-colors duration-500 hover:bg-primary hover:text-white md:bg-white/70"
			/>
		</li>
	</ul>
</nav>

<script>
	const detailsEl = document.getElementById("mobile-nav-details");
	if (detailsEl instanceof HTMLDetailsElement) {
		const navEl = document.getElementById("site-nav");
		const summaryEl = detailsEl.querySelector("summary");
		const menuEl = document.getElementById("mobile-menu");
		const menuLinks = menuEl?.querySelectorAll("a");

		const syncExpandedState = () => {
			navEl?.classList.toggle("mobile-menu-open", detailsEl.open);
			if (summaryEl) {
				summaryEl.setAttribute(
					"aria-expanded",
					detailsEl.open ? "true" : "false",
				);
			}
		};

		const setMenuOpen = (isOpen: boolean) => {
			detailsEl.open = isOpen;
			syncExpandedState();
		};

		const closeMenu = () => setMenuOpen(false);

		summaryEl?.addEventListener("click", event => {
			event.preventDefault();
			setMenuOpen(!detailsEl.open);
		});

		menuLinks?.forEach(link => {
			link.addEventListener("click", closeMenu);
		});

		document.addEventListener("keydown", event => {
			if (event.key === "Escape" && detailsEl.open) {
				closeMenu();
			}
		});

		document.addEventListener("click", event => {
			if (!detailsEl.open) return;
			if (!(event.target instanceof Node)) return;
			if (!detailsEl.contains(event.target)) {
				closeMenu();
			}
		});

		syncExpandedState();
	}
</script>

<style>
	@reference "../styles/global.css";

	#site-nav.mobile-menu-open {
		border-bottom-color: transparent;
	}

	details[open] #mobile-menu {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateY(0) scale(1);
	}

	details summary::-webkit-details-marker {
		display: none;
	}

	details summary {
		list-style: none;
	}

	details[open] #menu-line-1 {
		transform: rotate(45deg) translateY(6px);
	}

	details[open] #menu-line-2 {
		opacity: 0;
	}

	details[open] #menu-line-3 {
		transform: rotate(-45deg) translateY(-6px);
	}

	#menu-line-1,
	#menu-line-2,
	#menu-line-3 {
		transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
	}

	#mobile-menu > * {
		opacity: 0;
		transform: translateY(8px);
		transition:
			opacity 260ms ease,
			transform 300ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--menu-item-delay, 0ms);
	}

	details[open] #mobile-menu > * {
		opacity: 1;
		transform: translateY(0);
	}

	.nav-link {
		@apply block w-full rounded-lg px-4 py-3 text-xl font-semibold text-primary transition-colors duration-300 hover:bg-primary hover:text-white focus:outline-none focus:ring-2 focus:ring-tertiary md:rounded md:text-base;
	}
</style>
