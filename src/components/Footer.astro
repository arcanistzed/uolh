---
import { Trans } from "astro-i18next/components";
import { Icon } from 'astro-icon/components';
import { setDefaultNamespace, t } from "i18next";

setDefaultNamespace("footer");

const socialLinks = [
	{
		href: "https://www.instagram.com/uodpa_apnuo/",
		icon: "line-md:instagram",
		labelKey: "instagram",
		external: true,
	},
	{
		href: "mailto:uodpa.apnuo@gmail.com",
		icon: "line-md:email",
		labelKey: "email",
		external: false,
	},
	{
		href: "https://discord.gg/yNJNNfjRtV",
		icon: "line-md:discord",
		labelKey: "discord",
		external: true,
	},
];
---

<footer class="mx-auto mt-8 w-full max-w-4xl border-t border-primary/20 px-4 py-6 text-center">
	<nav aria-label="Social media links" class="mx-auto w-fit">
		<ul class="flex gap-2">
			{socialLinks.map(link => (
				<li>
					<a
						href={link.href}
						target={link.external ? "_blank" : undefined}
						rel={link.external ? "noopener noreferrer" : undefined}
						class="inline-flex rounded-md p-1 transition-colors hover:bg-primary/10"
					>
						<Icon name={link.icon} class="h-8 w-8 text-tertiary" />
						<span class="sr-only">{t(link.labelKey)}</span>
					</a>
				</li>
			))}
		</ul>
	</nav>
	<small class="mt-2 block text-sm text-quaternary/75">{t("copyright")}</small>
	<small class="mt-1 block text-sm text-quaternary/75">
		<Trans i18nKey="footer">
			Made with <span>♥</span> by <a href="https://danielthorp.com" target="_blank" rel="noopener noreferrer" class="font-bold text-primary hover:text-tertiary">
				Daniel Thorp
			</a>.
		</Trans>
	</small>
</footer>
