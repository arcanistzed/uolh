---
import { changeLanguage, setDefaultNamespace, t } from "i18next";
import { localizePath } from "astro-i18next";
import Layout from "../layouts/Layout.astro";

changeLanguage("en");

setDefaultNamespace("about");
---

<Layout title={t("title")} description={t("description")}>
	<main class="section-shell flex h-full flex-col gap-6">
		<h1 class="page-title">{t("heading")}</h1>
		<p class="text-lg font-semibold text-tertiary">{t("subheading")}</p>

		<section class="surface-card space-y-4">
			<p class="page-intro">{t("paragraph-1")}</p>
			<p class="page-intro">{t("paragraph-2")}</p>
			<p class="page-intro">{t("paragraph-3")}</p>
		</section>

		<section class="surface-card space-y-4">
			<h2 class="text-2xl font-bold text-primary">{t("objects-heading")}</h2>
			<ul class="list-disc space-y-2 pl-6 leading-relaxed text-quaternary/85">
				<li>{t("object-1")}</li>
				<li>{t("object-2")}</li>
			</ul>
		</section>

		<section class="surface-card space-y-4">
			<h2 class="text-2xl font-bold text-primary">{t("activities-heading")}</h2>
			<p class="page-intro">{t("activities")}</p>
		</section>

		<div class="mt-2 flex flex-wrap gap-4">
			<a
				href="https://forms.gle/qArg7RfNRrhedd1y7"
				target="_blank"
				rel="noopener noreferrer"
				referrerpolicy="no-referrer"
				class="btn-secondary"
			>
				{t("join-the-club")}
			</a>
			<a
				href={localizePath("/events")}
				class="btn-primary"
			>
				{t("explore-events")}
			</a>
		</div>
	</main>
</Layout>
