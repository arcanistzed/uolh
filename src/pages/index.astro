---
import { changeLanguage, setDefaultNamespace, t } from "i18next";
import { localizePath } from "astro-i18next";
import Layout from "../layouts/Layout.astro";

changeLanguage("en");

setDefaultNamespace("home");
---

<Layout title={t("title")} description={t("description")}>
	<div class="section-shell my-auto flex flex-col items-center gap-8">
		<h1
			class="max-w-4xl animate-[fade-up_700ms_forwards] text-center font-serif text-[clamp(2rem,5vw,3.75rem)] font-extrabold leading-tight tracking-wide text-primary opacity-0"
		>
			{t("heading")}
		</h1>
		<h2
			class="max-w-3xl animate-[fade-up_700ms_forwards_120ms] text-center text-2xl font-bold text-tertiary opacity-0"
		>
			{t("subheading")}
		</h2>
		<p
			class="surface-card max-w-4xl animate-[fade-up_700ms_forwards_240ms] text-center text-lg leading-relaxed text-quaternary/85 opacity-0"
		>
			{t("contents")}
		</p>
		<div
			class="flex animate-[fade-up_700ms_forwards_360ms] flex-wrap justify-center gap-4 opacity-0"
		>
			<a
				href="https://forms.gle/qArg7RfNRrhedd1y7"
				target="_blank"
				rel="noopener noreferrer"
				referrerpolicy="no-referrer"
				class="btn-secondary"
			>
				{t("join-the-club")}
			</a>
			<a href={localizePath("/events")} class="btn-primary">
				{t("explore-events")}
			</a>
		</div>
	</div>
</Layout>
